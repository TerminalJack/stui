<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Spectre.Console</id>
    <version>0.49.1</version>
    <authors>Patrik Svensson, Phil Scott, Nils Andresen, Cédric Luthi, Frank Ray</authors>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>small-logo.png</icon>
    <projectUrl>https://github.com/spectreconsole/spectre.console</projectUrl>
    <description>A library that makes it easier to create beautiful console applications.</description>
    <releaseNotes>https://github.com/spectreconsole/spectre.console/releases</releaseNotes>
    <copyright>Patrik Svensson, Phil Scott, Nils Andresen, Cédric Luthi, Frank Ray</copyright>
    <repository type="git" url="https://github.com/spectreconsole/spectre.console" commit="5d4b2c88e53f538b4ade5fba6207a25b0af80a66" />
    <dependencies>
      <group targetFramework="net6.0" />
      <group targetFramework="net7.0" />
      <group targetFramework="net8.0" />
      <group targetFramework=".NETStandard2.0">
        <dependency id="System.Memory" version="4.5.5" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>